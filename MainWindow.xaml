<Window x:Class="RDPManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:s="clr-namespace:RDPManager.Services"
        Title="{Binding AppTitle}" Width="860" Height="560"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        Background="#F0F2F5">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Card" Background="#FFFFFF"
                                BorderThickness="0" CornerRadius="8"
                                Padding="16,14" Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#E3F0FF"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="Shadow" BlurRadius="12" Opacity="0.08" ShadowDepth="2" Color="#000000"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔗" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppTitle}" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                    <TextBlock Text="{Binding AppSubtitle}" FontSize="11" Foreground="#C0E0FF" Margin="0,1,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#FFFFFF" Padding="16,10" Effect="{StaticResource Shadow}">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnConnect" Content="{Binding BtnConnect}" Style="{StaticResource ActionButton}" Background="#0078D4" Click="BtnConnect_Click" Width="90"/>
                <Rectangle Width="1" Fill="#E0E0E0" Margin="12,4"/>
                <Button x:Name="BtnAdd" Content="{Binding BtnAdd}" Style="{StaticResource ActionButton}" Background="#107C10" Click="BtnAdd_Click" Width="90"/>
                <Button x:Name="BtnEdit" Content="{Binding BtnEdit}" Style="{StaticResource ActionButton}" Background="#5C5C5C" Click="BtnEdit_Click" Width="80" Margin="8,0,0,0"/>
                <Button x:Name="BtnDelete" Content="{Binding BtnDelete}" Style="{StaticResource ActionButton}" Background="#D32F2F" Click="BtnDelete_Click" Width="80" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Connection List -->
        <Border Grid.Row="2" Margin="16,12,16,8" CornerRadius="8" Background="#FFFFFF" Effect="{StaticResource Shadow}">
            <Grid>
                <ListView x:Name="LvConnections"
                          BorderThickness="0"
                          Background="Transparent"
                          SelectionMode="Single"
                          MouseDoubleClick="LvConnections_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ServerAddress}" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="#888888" Margin="16,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Source={x:Static s:TranslationService.Instance}, Path=ColUsername}" FontSize="10" Foreground="#AAAAAA"/>
                                    <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#333333" Margin="0,1,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="2" VerticalAlignment="Center" Background="#F0F0F0" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="{Binding Source={x:Static s:TranslationService.Instance}, Path=LabelDoubleClick}" FontSize="11" Foreground="#999999"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock x:Name="TbEmpty" Text="{Binding EmptyState}"
                           FontSize="14" Foreground="#AAAAAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#E8E8E8" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TbStatus" Text="就绪" FontSize="11" Foreground="#666666" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LanguageLabel}" FontSize="11" Foreground="#666666" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="CbLanguage" SelectedIndex="0" Width="100" Height="22" FontSize="11"
                              SelectionChanged="CbLanguage_SelectionChanged">
                        <ComboBox.Items>
                            <ComboBoxItem Tag="zh-CN">简体中文</ComboBoxItem>
                            <ComboBoxItem Tag="en">English</ComboBoxItem>
                            <ComboBoxItem Tag="zh-Hant">繁體中文</ComboBoxItem>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
